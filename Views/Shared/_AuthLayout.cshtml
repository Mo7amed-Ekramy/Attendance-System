<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - University Attendance</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVC_PROJECT.styles.css" asp-append-version="true" />

    @await RenderSectionAsync("Head", required: false)
</head>
<body class="auth-body">
    <div class="auth-container">

        <div class="auth-card-wrapper">
            <div class="auth-card">
                <div class="auth-header text-center">
                    <div class="university-logo">
                        <i class="fas fa-graduation-cap fa-4x"></i>
                    </div>
                    <h1 class="auth-title">University Attendance</h1>
                    <p class="auth-subtitle">Track • Manage • Succeed</p>
                </div>

                <div class="auth-content mt-4">
                    @RenderBody()
                </div>

                <div class="auth-footer text-center mt-5">
                    <div class="auth-links mb-3">
                        @if (ViewContext.RouteData.Values["action"]?.ToString() == "Login")
                        {
                            <a href="/Account/Register">Don't have an account? <span class="fw-bold">Register Now</span></a>
                        }
                        else if (ViewContext.RouteData.Values["action"]?.ToString() == "Register")
                        {
                            <a href="/Account/Login">Already have an account? <span class="fw-bold">Login</span></a>
                        }
                    </div>
                    <p class="text-muted small">
                        &copy; @DateTime.Now.Year - University Attendance System
                    </p>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
@{
    ViewData["Title"] = "My Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">My Courses</h1>
        <p class="text-muted mb-0">Manage your teaching courses and configurations</p>
    </div>
    <div class="btn-group">
        <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="fas fa-filter me-2"></i> Filter
        </button>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">All Courses</a></li>
            <li><a class="dropdown-item" href="#">Current Semester</a></li>
            <li><a class="dropdown-item" href="#">Active Only</a></li>
        </ul>
        <a href="#" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i> New Course
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card course-card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold">CS101</h5>
                        <small>Introduction to Programming</small>
                    </div>
                    <span class="badge bg-light text-primary">Spring 2024</span>
                </div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Total Students</small>
                        <small class="fw-bold">100</small>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Sections</small>
                        <small class="fw-bold">4 Sections</small>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Attendance Rate</small>
                        <small class="fw-bold">92%</small>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 92%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Status</small>
                        <div>
                            <span class="badge bg-success">Excellent</span>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4">
                    <div class="row">
                        <div class="col-6">
                            <small class="text-muted d-block">TAs Assigned</small>
                            <small class="fw-bold">4 TAs</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Next Lecture</small>
                            <small class="fw-bold">Tomorrow</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white border-0">
                <div class="d-grid gap-2">
                    <a href="/Doctor/CourseConfiguration?courseId=1" class="btn btn-primary">
                        <i class="fas fa-cog me-2"></i> Configure
                    </a>
                    <div class="btn-group">
                        <a href="/Doctor/TakeLectureAttendance?courseId=1" class="btn btn-outline-primary">
                            <i class="fas fa-calendar-check me-2"></i> Attendance
                        </a>
                        <a href="/Doctor/FullCourseReport?courseId=1" class="btn btn-outline-primary">
                            <i class="fas fa-chart-bar me-2"></i> Report
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card course-card shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold">CS201</h5>
                        <small>Data Structures</small>
                    </div>
                    <span class="badge bg-light text-info">Spring 2024</span>
                </div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Total Students</small>
                        <small class="fw-bold">96</small>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Sections</small>
                        <small class="fw-bold">4 Sections</small>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Attendance Rate</small>
                        <small class="fw-bold">78%</small>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-warning" style="width: 78%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Status</small>
                        <div>
                            <span class="badge bg-warning">Needs Attention</span>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4">
                    <div class="row">
                        <div class="col-6">
                            <small class="text-muted d-block">TAs Assigned</small>
                            <small class="fw-bold">4 TAs</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Next Lecture</small>
                            <small class="fw-bold">Day After Tomorrow</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white border-0">
                <div class="d-grid gap-2">
                    <a href="/Doctor/CourseConfiguration?courseId=2" class="btn btn-info">
                        <i class="fas fa-cog me-2"></i> Configure
                    </a>
                    <div class="btn-group">
                        <a href="/Doctor/LectureReports?courseId=2" class="btn btn-outline-info">
                            <i class="fas fa-chart-line me-2"></i> Review
                        </a>
                        <a href="/Doctor/FullCourseReport?courseId=2" class="btn btn-outline-info">
                            <i class="fas fa-file-alt me-2"></i> Report
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card course-card shadow-sm h-100">
            <div class="card-header bg-danger text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold">MATH101</h5>
                        <small>Calculus</small>
                    </div>
                    <span class="badge bg-light text-danger">Spring 2024</span>
                </div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Total Students</small>
                        <small class="fw-bold">104</small>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Sections</small>
                        <small class="fw-bold">4 Sections</small>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Attendance Rate</small>
                        <small class="fw-bold">65%</small>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-danger" style="width: 65%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Status</small>
                        <div>
                            <span class="badge bg-danger">Critical</span>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4">
                    <div class="row">
                        <div class="col-6">
                            <small class="text-muted d-block">TAs Assigned</small>
                            <small class="fw-bold">4 TAs</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Next Lecture</small>
                            <small class="fw-bold">Tomorrow, 09:00 AM</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white border-0">
                <div class="d-grid gap-2">
                    <a href="/Doctor/CourseConfiguration?courseId=3" class="btn btn-danger">
                        <i class="fas fa-cog me-2"></i> Configure
                    </a>
                    <div class="btn-group">
                        <a href="/Doctor/TakeLectureAttendance?courseId=3" class="btn btn-outline-danger">
                            <i class="fas fa-calendar-check me-2"></i> Attendance
                        </a>
                        <a href="/Doctor/LectureReports?courseId=3" class="btn btn-outline-danger">
                            <i class="fas fa-chart-line me-2"></i> Investigate
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h6 class="m-0 fw-bold"><i class="fas fa-tasks me-2 text-primary"></i> Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <a href="/Doctor/CourseConfiguration" class="btn btn-outline-primary w-100 h-100 d-flex flex-column align-items-center justify-content-center p-3">
                            <i class="fas fa-cog fa-2x mb-2"></i>
                            <div class="fw-bold">Course Configuration</div>
                            <small class="text-muted">Set policies and weights</small>
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="/Doctor/TakeLectureAttendance" class="btn btn-outline-success w-100 h-100 d-flex flex-column align-items-center justify-content-center p-3">
                            <i class="fas fa-chalkboard-teacher fa-2x mb-2"></i>
                            <div class="fw-bold">Take Lecture Attendance</div>
                            <small class="text-muted">Record lecture attendance</small>
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="/Doctor/LectureReports" class="btn btn-outline-info w-100 h-100 d-flex flex-column align-items-center justify-content-center p-3">
                            <i class="fas fa-chart-line fa-2x mb-2"></i>
                            <div class="fw-bold">Lecture Reports</div>
                            <small class="text-muted">View lecture analytics</small>
                        </a>
                    </div>
                    <div class="col-md-3 mb-3">
                        <a href="/Doctor/FullCourseReport" class="btn btn-outline-warning w-100 h-100 d-flex flex-column align-items-center justify-content-center p-3">
                            <i class="fas fa-file-alt fa-2x mb-2"></i>
                            <div class="fw-bold">Full Course Report</div>
                            <small class="text-muted">Generate course reports</small>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
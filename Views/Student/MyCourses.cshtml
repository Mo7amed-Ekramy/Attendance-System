                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-warning" style="width: 78%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Absences</small>
                        <div>
                            <span class="badge bg-warning">4/5</span>
                            <small class="text-muted ms-1">Warning</small>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4">
                    <div class="row">
                        <div class="col-6">
                            <small class="text-muted d-block">Doctor</small>
                            <small class="fw-bold">Dr. Omar Hassan</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">TA</small>

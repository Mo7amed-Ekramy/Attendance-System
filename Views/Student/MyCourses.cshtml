@{
    ViewData["Title"] = "My Courses";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0">My Courses</h1>
        <p class="text-muted mb-0">View all your enrolled courses and progress</p>
    </div>
    <div class="btn-group">
        <button class="btn btn-outline-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
            <i class="fas fa-filter me-2"></i> Filter
        </button>
        <ul class="dropdown-menu">
            <li><a class="dropdown-item" href="#">All Courses</a></li>
            <li><a class="dropdown-item" href="#">Current Semester</a></li>
            <li><a class="dropdown-item" href="#">Previous Semesters</a></li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#">By Status</a></li>
        </ul>
    </div>
</div>

<div class="row">
    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card course-card shadow-sm h-100">
            <div class="card-header bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold">CS101</h5>
                        <small>Introduction to Programming</small>
                    </div>
                    <span class="badge bg-light text-primary">Spring 2024</span>
                </div>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Attendance</small>
                        <small class="fw-bold">92%</small>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 92%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Quiz Average</small>
                        <small class="fw-bold">85/100</small>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-info" style="width: 85%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <small class="text-muted">Coursework Grade</small>
                        <small class="fw-bold">A</small>
                    </div>
                    <div class="progress" style="height: 6px;">
                        <div class="progress-bar bg-success" style="width: 92%"></div>
                    </div>
                </div>
                
                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <small class="text-muted">Absences</small>
                        <div>
                            <span class="badge bg-success">2/5</span>
                            <small class="text-muted ms-1">Safe</small>
                        </div>
                    </div>
                </div>
                
                <div class="mt-4">
                    <div class="row">
                        <div class="col-6">
                            <small class="text-muted d-block">Doctor</small>
                            <small class="fw-bold">Dr. Ahmed Mohamed</small>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">TA</small>
                            <small class="fw-bold">TA Sarah Ali</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white border-0">
                <a href="/Student/CourseDetails?id=1" class="btn btn-primary w-100">
                    <i class="fas fa-eye me-2"></i> View Details
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6 col-lg-4 mb-4">
        <div class="card course-card shadow-sm h-100">
            <div class="card-header bg-info text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="mb-0 fw-bold">CS201</h5>
                        <small>Data Structures</small>
                    </div>

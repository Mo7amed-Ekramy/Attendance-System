                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">TA</small>
                            <small class="fw-bold">TA Khalid Mahmoud</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer bg-white border-0">
                <a href="/Student/CourseDetails?id=3" class="btn btn-danger w-100">
                    <i class="fas fa-eye me-2"></i> View Details
                </a>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm mt-4">
    <div class="card-header bg-white">
        <h6 class="m-0 fw-bold"><i class="fas fa-info-circle me-2 text-primary"></i> Status Legend</h6>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <div class="badge bg-success me-2" style="width: 20px; height: 20px;"></div>
                    <div>
                        <div class="fw-bold">Safe</div>
                        <small class="text-muted">Attendance > 80%</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <div class="badge bg-warning me-2" style="width: 20px; height: 20px;"></div>
                    <div>
                        <div class="fw-bold">Warning</div>
                        <small class="text-muted">Attendance 60-80%</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <div class="badge bg-danger me-2" style="width: 20px; height: 20px;"></div>
                    <div>
                        <div class="fw-bold">At Risk</div>
                        <small class="text-muted">Attendance < 60%</small>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="d-flex align-items-center mb-2">
                    <div class="badge bg-secondary me-2" style="width: 20px; height: 20px;"></div>
                    <div>
                        <div class="fw-bold">Deprived</div>
                        <small class="text-muted">Exceeded absences</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
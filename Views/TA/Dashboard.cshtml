@{
    ViewData["Title"] = "TA Dashboard";
}

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-primary border-3 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs fw-bold text-primary text-uppercase mb-1">Assigned Sections</div>
                        <div class="h5 mb-0 fw-bold">4</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-success border-3 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs fw-bold text-success text-uppercase mb-1">Students in Sections</div>
                        <div class="h5 mb-0 fw-bold">98</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-user-graduate fa-2x text-success"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-warning border-3 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs fw-bold text-warning text-uppercase mb-1">Attendance to Take</div>
                        <div class="h5 mb-0 fw-bold">3</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-calendar-check fa-2x text-warning"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-start border-danger border-3 shadow-sm h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs fw-bold text-danger text-uppercase mb-1">Quizzes to Grade</div>
                        <div class="h5 mb-0 fw-bold">2</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-tasks fa-2x text-danger"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <h6 class="m-0 fw-bold"><i class="fas fa-users me-2 text-primary"></i> My Sections</h6>
                <a href="/TA/MySections" class="btn btn-sm btn-outline-primary">Manage Sections</a>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Section</th>
                                <th>Course</th>
                                <th>Students</th>
                                <th>Attendance Rate</th>
                                <th>Next Session</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>
                                    <div class="fw-bold">CS101 - Section 1</div>
                                    <small class="text-muted">Mon 10:00 AM - Lab 302</small>
                                </td>
                                <td>Introduction to Programming</td>
                                <td>25</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-2" style="height: 6px;">
                                            <div class="progress-bar bg-success" style="width: 92%"></div>
                                        </div>
                                        <span class="small">92%</span>
                                    </div>
                                </td>
                                <td>Tomorrow, 10:00 AM</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/TA/TakeAttendance?sectionId=1" class="btn btn-primary">Take Attendance</a>
                                        <a href="/TA/CreateQuiz?sectionId=1" class="btn btn-outline-primary">Create Quiz</a>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="fw-bold">CS201 - Section 3</div>
                                    <small class="text-muted">Wed 02:00 PM - Room 205</small>
                                </td>
                                <td>Data Structures</td>
                                <td>24</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-2" style="height: 6px;">
                                            <div class="progress-bar bg-warning" style="width: 75%"></div>
                                        </div>
                                        <span class="small">75%</span>
                                    </div>
                                </td>
                                <td>Wednesday, 02:00 PM</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/TA/TakeAttendance?sectionId=2" class="btn btn-primary">Take Attendance</a>
                                        <a href="/TA/CreateQuiz?sectionId=2" class="btn btn-outline-primary">Create Quiz</a>
                                    </div>
                                </td>
                            </tr>
                            <tr>
                                <td>
                                    <div class="fw-bold">MATH101 - Section 2</div>
                                    <small class="text-muted">Thu 09:00 AM - Room 101</small>
                                </td>
                                <td>Calculus</td>
                                <td>26</td>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="progress flex-grow-1 me-2" style="height: 6px;">
                                            <div class="progress-bar bg-danger" style="width: 65%"></div>
                                        </div>
                                        <span class="small">65%</span>
                                    </div>
                                </td>
                                <td>Thursday, 09:00 AM</td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a href="/TA/TakeAttendance?sectionId=3" class="btn btn-primary">Take Attendance</a>
                                        <a href="/TA/RecordQuizMarks?quizId=5" class="btn btn-outline-warning">Grade Quiz</a>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4 mb-4">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h6 class="m-0 fw-bold"><i class="fas fa-tasks me-2 text-primary"></i> Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a href="/TA/TakeAttendance?sectionId=1" class="btn btn-primary btn-lg">
                        <i class="fas fa-calendar-check me-2"></i> Take Attendance
                    </a>
                    <a href="/TA/CreateQuiz?sectionId=1" class="btn btn-outline-primary btn-lg">
                        <i class="fas fa-plus-circle me-2"></i> Create New Quiz
                    </a>
                    <a href="/TA/RecordQuizMarks?quizId=5" class="btn btn-outline-warning btn-lg">
                        <i class="fas fa-tasks me-2"></i> Record Quiz Marks
                    </a>
                    <a href="/TA/SectionReports?sectionId=1" class="btn btn-outline-info btn-lg">
                        <i class="fas fa-chart-bar me-2"></i> View Reports
                    </a>
                </div>
                
                <div class="mt-4">
                    <h6 class="fw-bold mb-3"><i class="fas fa-exclamation-circle me-2 text-warning"></i> Attention Needed</h6>
                    <div class="list-group">
                        <div class="list-group-item border-0 bg-light">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <div class="fw-bold small">Low Attendance</div>
                                    <div class="text-muted small">MATH101 - Section 2 has 65% attendance</div>
                                </div>
                                <span class="badge bg-warning">Warning</span>
                            </div>
                        </div>
                        <div class="list-group-item border-0 bg-light">
                            <div class="d-flex justify-content-between">
                                <div>
                                    <div class="fw-bold small">Pending Quiz</div>
                                    <div class="text-muted small">Quiz 3 needs to be graded for CS201</div>
                                </div>
                                <span class="badge bg-danger">Urgent</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-header bg-white">
                <h6 class="m-0 fw-bold"><i class="fas fa-history me-2 text-primary"></i> Recent Activities</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Time</th>
                                <th>Action</th>
                                <th>Section</th>
                                <th>Details</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>2 hours ago</td>
                                <td><span class="badge bg-success">Attendance Taken</span></td>
                                <td>CS101 - Section 1</td>
                                <td>25 students, 23 present, 2 absent</td>
                            </tr>
                            <tr>
                                <td>1 day ago</td>
                                <td><span class="badge bg-info">Quiz Created</span></td>
                                <td>CS201 - Section 3</td>
                                <td>Quiz 3 created, max marks: 20</td>
                            </tr>
                            <tr>
                                <td>2 days ago</td>
                                <td><span class="badge bg-warning">Quiz Marks Recorded</span></td>
                                <td>MATH101 - Section 2</td>
                                <td>Quiz 2 marks recorded for 26 students</td>
                            </tr>
                            <tr>
                                <td>3 days ago</td>
                                <td><span class="badge bg-primary">Report Generated</span></td>
                                <td>CS101 - Section 1</td>
                                <td>Weekly attendance report generated</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
@{
    ViewData["Title"] = "Dashboard Overview";
}

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-doctor text-white rounded-circle p-3 me-3">
                    <i class="fas fa-user-graduate fa-2x"></i>
                </div>
                <div>
                    <h6 class="stat-label text-muted mb-1">Total Students</h6>
                    <h3 class="stat-value mb-0">@ViewData["TotalStudents"]</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-ta text-white rounded-circle p-3 me-3">
                    <i class="fas fa-book-open fa-2x"></i>
                </div>
                <div>
                    <h6 class="stat-label text-muted mb-1">Active Courses</h6>
                    <h3 class="stat-value mb-0">@ViewData["ActiveCourses"]</h3>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4 mb-4">
        <div class="card stat-card h-100 border-0 shadow-sm">
            <div class="card-body d-flex align-items-center">
                <div class="stat-icon bg-student text-white rounded-circle p-3 me-3">
                    <i class="fas fa-percentage fa-2x"></i>
                </div>
                <div>
                    <h6 class="stat-label text-muted mb-1">Attendance Rate</h6>
                    <h3 class="stat-value mb-0">@ViewData["AttendanceRate"]</h3>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row mt-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white border-bottom-0 py-3">
                <h5 class="mb-0 fw-bold"><i class="fas fa-history me-2 text-primary"></i> Recent Activities</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Student Name</th>
                                <th>Course</th>
                                <th>Status</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>Ahmed Mohamed</td>
                                <td>Advanced .NET Core</td>
                                <td><span class="badge bg-success">Present</span></td>
                                <td>10:30 AM</td>
                            </tr>
                            <tr>
                                <td>Sara Ahmed</td>
                                <td>Database Systems</td>
                                <td><span class="badge bg-danger">Absent</span></td>
                                <td>09:15 AM</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>